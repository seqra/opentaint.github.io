---
import { DemoSection } from "@/components/DemoSection";
---

<link rel="prefetch" href="/demo/hero.cast" as="fetch" crossorigin="anonymous" />

<section class="band demo-section pt-0 pb-12 sm:pt-2 sm:pb-14 lg:pt-4 lg:pb-16">
  <DemoSection client:visible />
</section>

<style>
  /* On mobile the demo is a single full-bleed scan cast — drop the section's
     horizontal padding so the terminal reaches the viewport edges. Above sm
     (640px), the frame padding returns. */
  @media (max-width: 639px) {
    .demo-section.band {
      padding-inline: 0;
    }
  }
</style>
