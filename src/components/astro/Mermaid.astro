---
type Props = {
  chart: string;
};

const { chart } = Astro.props;
---

<div class="mermaid-chart" data-mermaid-source={encodeURIComponent(chart)}></div>

<script>
  async function renderMermaidCharts() {
    const charts = document.querySelectorAll(".mermaid-chart:not([data-rendered])");
    if (charts.length === 0) return;

    const isDark = document.documentElement.classList.contains("dark");

    const lightVars = {
      primaryColor: "#f5f5f4",
      primaryTextColor: "#1c1917",
      primaryBorderColor: "#a8a29e",
      secondaryColor: "#e7e5e4",
      secondaryTextColor: "#292524",
      secondaryBorderColor: "#a8a29e",
      tertiaryColor: "#fafaf9",
      tertiaryTextColor: "#1c1917",
      tertiaryBorderColor: "#d6d3d1",
      lineColor: "#78716c",
      textColor: "#44403c",
      mainBkg: "#f5f5f4",
      nodeBorder: "#a8a29e",
      clusterBkg: "#fafaf9",
      clusterBorder: "#d6d3d1",
      titleColor: "#1c1917",
      edgeLabelBackground: "#ffffff",
      nodeTextColor: "#1c1917",
      actorBkg: "#f5f5f4",
      actorBorder: "#a8a29e",
      actorTextColor: "#1c1917",
      actorLineColor: "#a8a29e",
      signalColor: "#57534e",
      signalTextColor: "#1c1917",
      labelBoxBkgColor: "#fafaf9",
      labelBoxBorderColor: "#d6d3d1",
      labelTextColor: "#44403c",
      loopTextColor: "#57534e",
      noteBkgColor: "#fef2f2",
      noteBorderColor: "#cf2528",
      noteTextColor: "#991b1b",
      activationBkgColor: "#e7e5e4",
      activationBorderColor: "#a8a29e",
      sequenceNumberColor: "#ffffff",
    };

    const darkVars = {
      primaryColor: "#1c1917",
      primaryTextColor: "#e7e5e4",
      primaryBorderColor: "#57534e",
      secondaryColor: "#292524",
      secondaryTextColor: "#d6d3d1",
      secondaryBorderColor: "#57534e",
      tertiaryColor: "#0a0a0a",
      tertiaryTextColor: "#e7e5e4",
      tertiaryBorderColor: "#44403c",
      lineColor: "#78716c",
      textColor: "#a8a29e",
      mainBkg: "#1c1917",
      nodeBorder: "#57534e",
      clusterBkg: "#0a0a0a",
      clusterBorder: "#292524",
      titleColor: "#e7e5e4",
      edgeLabelBackground: "#0a0a0a",
      nodeTextColor: "#e7e5e4",
      actorBkg: "#1c1917",
      actorBorder: "#57534e",
      actorTextColor: "#e7e5e4",
      actorLineColor: "#57534e",
      signalColor: "#a8a29e",
      signalTextColor: "#e7e5e4",
      labelBoxBkgColor: "#0a0a0a",
      labelBoxBorderColor: "#292524",
      labelTextColor: "#a8a29e",
      loopTextColor: "#78716c",
      noteBkgColor: "#1a0000",
      noteBorderColor: "#cf2528",
      noteTextColor: "#fca5a5",
      activationBkgColor: "#292524",
      activationBorderColor: "#57534e",
      sequenceNumberColor: "#ffffff",
    };

    const { default: mermaid } = await import("mermaid");
    mermaid.initialize({
      startOnLoad: false,
      theme: "base",
      fontFamily: "'JetBrains Mono', ui-monospace, monospace",
      themeVariables: isDark ? darkVars : lightVars,
      flowchart: { curve: "basis", padding: 20, nodeSpacing: 50, rankSpacing: 60, htmlLabels: true },
      sequence: { actorMargin: 80, messageFontSize: 13, noteMargin: 12, messageMargin: 40, mirrorActors: false, bottomMarginAdj: 2, useMaxWidth: true },
    });

    let id = 0;
    for (const el of charts) {
      const source = decodeURIComponent((el as HTMLElement).dataset.mermaidSource || "");
      if (!source) continue;
      el.setAttribute("data-rendered", "true");
      try {
        const { svg } = await mermaid.render(`mermaid-${++id}`, source);
        el.innerHTML = `<div class="my-6 rounded-xl border border-border p-6" style="background: hsl(var(--code-bg))"><div class="flex justify-center overflow-x-auto [&_svg]:max-w-full">${svg}</div></div>`;
      } catch (err) {
        el.innerHTML = `<pre class="bg-destructive/10 text-destructive p-4 rounded-lg text-sm overflow-auto mb-6">${String(err)}</pre>`;
      }
    }
  }

  renderMermaidCharts();

  const themeToggle = document.querySelector("[data-theme-toggle]");
  if (themeToggle) {
    themeToggle.addEventListener("click", () => {
      setTimeout(() => {
        document.querySelectorAll(".mermaid-chart[data-rendered]").forEach((el) => {
          el.removeAttribute("data-rendered");
        });
        renderMermaidCharts();
      }, 50);
    });
  }
</script>
