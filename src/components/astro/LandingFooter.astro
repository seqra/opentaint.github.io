---
interface Props {
  /* Mirror the red separator's hooks so the footer continues a page's
     alternating zigzag. Set true on pages where an even number of separators
     precede the footer (e.g. the blog index and blog posts). */
  mirror?: boolean;
}

const { mirror = false } = Astro.props;

const links = [
  { href: "https://github.com/seqra/opentaint", label: "GitHub", external: true },
  { href: "https://discord.gg/6BXDfbP4p9", label: "Discord", external: true },
  { href: "/blog", label: "Blog", external: false },
  { href: "mailto:seqradev@gmail.com", label: "Contact", external: false },
];
---

<footer>
  <div class:list={["footer-links grid grid-cols-2 sm:grid-cols-4", mirror && "footer-alt"]}>
    {links.map((link) => (
      <a
        href={link.href}
        target={link.external ? "_blank" : undefined}
        rel={link.external ? "noopener noreferrer" : undefined}
        class="flex items-center justify-center py-5 font-mono text-sm font-medium text-muted-foreground transition-colors hover:text-primary lg:py-6 lg:text-[15px]"
      >
        {link.label}
      </a>
    ))}
  </div>

  <div class="flex items-center justify-center py-6 lg:py-8">
    <span class="font-mono text-xs text-muted-foreground lg:text-[13px]">&copy; 2026 Seqra Team</span>
  </div>
</footer>

<style>
  /* Divider styling is shared globally via `.footer-links` in index.css. */
  .footer-links {
    position: relative;
  }
</style>
