---
import { faqItems } from "@/lib/faq";
---

<section class="page-section" aria-labelledby="faq-heading">
  <h2 id="faq-heading" class="section-title text-center">FAQ</h2>

  <ul class="mx-auto mt-6 max-w-3xl lg:mt-8">
    {faqItems.map((item, index) => (
      <li class="border-r-2 border-transparent pr-4 sm:pr-16 transition-colors" data-faq-item>
        <button
          type="button"
          class="flex w-full items-center gap-3 py-4 pr-4 text-left font-mono text-[15px] text-foreground transition-colors hover:text-primary lg:text-base lg:py-5 lg:pr-5"
          aria-expanded="false"
          aria-controls={`faq-answer-${index}`}
          data-faq-toggle
        >
          <svg
            data-faq-chevron
            class="size-4 flex-shrink-0 text-muted-foreground transition-transform duration-200"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M6 3l5 5-5 5" />
          </svg>
          <span>{item.question}</span>
        </button>
        <div id={`faq-answer-${index}`} class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out motion-reduce:transition-none" data-faq-answer>
          <div class="overflow-hidden">
            <div class="pb-4 pl-4 font-mono text-[15px] leading-[185%] text-muted-foreground lg:text-base lg:pb-5 lg:pl-5">
              {item.isContact ? (
                <span>
                  Ask us on{" "}
                  <a
                    href="https://discord.gg/6BXDfbP4p9"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-primary underline transition-colors hover:text-foreground"
                  >
                    Discord
                  </a>
                </span>
              ) : (
                item.answer
              )}
            </div>
          </div>
        </div>
      </li>
    ))}
  </ul>
</section>

<script>
  document.querySelectorAll("[data-faq-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const item = btn.closest("[data-faq-item]");
      if (!item) return;
      const answer = item.querySelector("[data-faq-answer]");
      if (!answer) return;
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      const chevron = btn.querySelector("[data-faq-chevron]");
      btn.setAttribute("aria-expanded", String(!isOpen));
      if (answer instanceof HTMLElement) {
        answer.style.gridTemplateRows = !isOpen ? "1fr" : "0fr";
      }
      item.classList.toggle("border-transparent", isOpen);
      item.classList.toggle("border-primary", !isOpen);
      if (chevron) chevron.classList.toggle("rotate-90", !isOpen);
    });
  });
</script>
