---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/astro/SiteHeader.astro";
import LandingFooter from "@/components/astro/LandingFooter.astro";
import Breadcrumbs from "@/components/astro/Breadcrumbs.astro";
import { getPostSummaries } from "@/lib/content";
import { siteConfig } from "@/lib/site";

const posts = await getPostSummaries();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteConfig.url,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: `${siteConfig.url}/blog`,
    },
  ],
};
---

<BaseLayout
  title="OpenTaint Blog | Releases, Comparisons, and Technical Notes on Taint Data Flow Analysis"
  description="Releases, comparisons, and technical notes on taint data flow analysis."
  keywords={["opentaint blog", "taint analysis articles", "sast comparison", "java security blog", "static analysis guides"]}
  structuredData={breadcrumbSchema}
>
  <div class="min-h-screen bg-background flex flex-col">
    <SiteHeader />
    <main id="main" class="flex-1 pt-16">
      <div class="page-container">
        <section class="page-section">
          <Breadcrumbs items={[
            { label: "Home", href: "/" },
            { label: "Blog" },
          ]} />
          <h1 class="font-mono text-[26px] font-bold tracking-tight text-foreground sm:text-[30px] md:text-[38px] md:leading-[1.15] lg:text-[42px] mt-4">Blog</h1>
          <p class="section-subtitle">Releases, comparisons, and technical notes on taint data flow analysis.</p>
        </section>

        <section class="page-section">
          <div class="space-y-0">
            {posts.map((post) => (
              <article class="border-b border-border py-5 last:border-0 lg:py-6">
                <h2 class="font-mono text-base font-medium text-foreground lg:text-[17px]">
                  <a href={`/blog/${post.slug}`} class="transition-colors hover:text-primary">
                    {post.title}
                  </a>
                </h2>
                <p class="mt-1.5 font-mono text-base leading-[185%] text-muted-foreground lg:text-[17px]">{post.description}</p>
                <div class="mt-3 font-mono text-[10px] text-muted-foreground sm:text-xs lg:text-[13px]">
                  <span>{new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
                </div>
              </article>
            ))}
          </div>
        </section>

        <LandingFooter />
      </div>
    </main>
  </div>
</BaseLayout>
