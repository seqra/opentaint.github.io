---
type BreadcrumbItem = {
  label: string;
  href?: string;
};

type Props = {
  items: BreadcrumbItem[];
};

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="font-mono text-[10px] uppercase tracking-[0.14em] text-muted-foreground sm:text-xs">
  <ol class="flex items-center gap-1.5">
    {items.map((item, index) => (
      <li class="flex items-center gap-1.5">
        {index > 0 && (
          <span aria-hidden="true" class="text-border">/</span>
        )}
        {item.href ? (
          <a href={item.href} class="transition-colors hover:text-primary">
            {item.label}
          </a>
        ) : (
          <span class="text-foreground/70">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
