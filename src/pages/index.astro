---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/astro/SiteHeader.astro";
import LandingFooter from "@/components/astro/LandingFooter.astro";
import { AnimatedHero } from "@/components/AnimatedHero";
import Demo from "@/components/astro/Demo.astro";
import WhatIsOpenTaint from "@/components/astro/WhatIsOpenTaint.astro";
import SupportedTechnology from "@/components/astro/SupportedTechnology.astro";
import FAQ from "@/components/astro/FAQ.astro";
import { defaultKeywords, siteConfig } from "@/lib/site";
import { faqItems } from "@/lib/faq";

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteConfig.title,
    alternateName: ["opentaint", "opentaint.org"],
    url: siteConfig.url,
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: siteConfig.title,
    url: siteConfig.url,
    logo: `${siteConfig.url}/logo.png`,
    sameAs: [
      siteConfig.github,
      siteConfig.discord,
      "https://twitter.com/seqradev",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: siteConfig.title,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Linux, macOS, Windows",
    description: "The open source taint analysis engine for the AI era. Formal taint analysis for application security — finds what AST-pattern matchers miss, lets LLM agents enact vulnerabilities as rules, scales where neither can alone. The most thorough taint analysis engine for Spring apps.",
    url: siteConfig.url,
    downloadUrl: "https://github.com/seqra/opentaint/releases",
    license: "https://www.apache.org/licenses/LICENSE-2.0",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "USD",
    },
    author: {
      "@type": "Organization",
      name: siteConfig.author,
      url: siteConfig.url,
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems
      .filter((item) => !item.isContact && item.answer)
      .map((item) => ({
        "@type": "Question",
        name: item.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: item.answer,
        },
      })),
  },
];
---

<BaseLayout
  title="OpenTaint | The Open Source Taint Analysis Engine for the AI Era"
  description="The open source taint analysis engine for the AI era. Formal taint analysis for application security — finds what AST-pattern matchers miss, lets LLM agents enact rules from vulnerabilities, scales where neither can alone."
  keywords={defaultKeywords}
  structuredData={structuredData}
>
  <div class="min-h-screen bg-background flex flex-col">
    <SiteHeader />
    <main id="main" class="flex-1 pt-16">
      <section class="band band-tint pt-10 pb-12 sm:pt-16 sm:pb-11 lg:pt-20 lg:pb-14">
        <AnimatedHero client:load />
      </section>

      <Demo />

      <WhatIsOpenTaint />

      <SupportedTechnology />
      <FAQ />

      <div class="frame-x">
        <LandingFooter />
      </div>
    </main>
  </div>
</BaseLayout>
